DB_ADMIN_PASSWORD=change-me-strong-db-admin-password
DB_USER=centinela_social_app
DB_PASSWORD=change-me-strong-db-app-password
DB_MIGRATOR_USER=centinela_social_migrator
DB_MIGRATOR_PASSWORD=change-me-strong-db-migrator-password
DB_MONITOR_USER=centinela_social_monitor
DB_MONITOR_PASSWORD=change-me-strong-db-monitor-password
DB_AUDIT_USER=centinela_social_audit
DB_AUDIT_PASSWORD=change-me-strong-db-audit-password
DB_HOST=db
DB_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_MONITOR_USER=centinela_monitor
REDIS_MONITOR_PASSWORD=change-me-strong-redis-monitor-password

