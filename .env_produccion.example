SECRET_KEY=change-me-use-strong-random-value
JWT_SIGNING_KEY=change-me-shared-jwt-signing-key
JWT_ALGORITHM=HS256

DEBUG=False
ALLOWED_HOSTS=centinela.epn.edu.ec,social-consensus-web,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://centinela.epn.edu.ec

DB_NAME=centinela_social
